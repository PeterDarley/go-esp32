{
  "name": "tinygo-esp32",
  "runArgs": [
    "--privileged"
  ],
  "postCreateCommand": "sudo usermod -a -G dialout vscode",
  "postStartCommand": "ls /dev/ttyUSB* 2>/dev/null | xargs -r sudo chmod 666",
  "customizations": {
    "vscode": {
      "extensions": ["golang.go", "tinygo.vscode-tinygo"]
    }
  }
}
